# Root-level local configuration template
# Copy to .env and fill with your own credentials.

ALPHAVANTAGE_API_KEY=
DATABENTO_API_KEY=

# Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/coffee_futures

# Redis (optional)
REDIS_URL=redis://localhost:6379

# News
NEWS_API_KEY=
API_NINJAS_KEY=

# LLM summarization
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional internal auth for API routes
INTERNAL_API_TOKEN=
